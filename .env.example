APP_NAME="CRM Engine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8081
APP_PORT=8081

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR
APP_TIMEZONE=Europe/Istanbul

APP_MAINTENANCE_DRIVER=file
COMPOSER_AUTH=
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=crm
DB_USERNAME=crm
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret
DB_FORWARD_PORT=3307

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_FORWARD_PORT=6380

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="crm@sanalkopru.local"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_FORWARD_PORT=8026

CRM_CURRENCY=TRY
CRM_TAX_RATE=20
CRM_ROUTE_PREFIX=admin/crm
CRM_TENANCY_MODE=single
CRM_DEFAULT_ORGANIZATION_NAME="Default Organization"
CRM_AI_ENABLED=false
CRM_AI_DRIVER=openai
CRM_AI_MODEL=

OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_BASE_URL=
OPENAI_REQUEST_TIMEOUT=30
OPENAI_MODEL=gpt-4o-mini

CLAUDE_API_KEY=
CLAUDE_BASE_URL=
CLAUDE_REQUEST_TIMEOUT=30
CLAUDE_MODEL=

GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_REQUEST_TIMEOUT=30
GEMINI_MODEL=

VITE_APP_NAME="${APP_NAME}"
