{
    "name": "sanalkopru/crm",
    "description": "Reusable CRM Engine package for Sanal Kopru Laravel projects.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0",
        "openspout/openspout": "^5.3",
        "sanalkopru/admin-panel": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Sanalkopru\\Crm\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sanalkopru\\Crm\\CrmServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
